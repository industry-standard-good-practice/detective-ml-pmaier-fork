{
  "name": "detective-ml-backend",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": ".venv/bin/uvicorn app.main:fastapi_app --reload --host 0.0.0.0 --port 4000",
    "start": "uvicorn app.main:fastapi_app --host 0.0.0.0 --port ${PORT:-8080}",
    "install:python": "pip install -r requirements.txt",
    "setup": "python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "lint": "python3 -m py_compile app/main.py"
  }
}
