# Firebase Admin SDK Service Account
# Option A: Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=.auth/serviceAccountKey.json

# Option B: JSON string (for cloud deployments)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"detectiveml",...}

# Firebase Configuration
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Server Configuration
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Secrets
# GEMINI_API_KEY is loaded from .env.local (gitignored) — see .env.local
